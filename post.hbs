{{!< default}}

{{#post}}

<div class="progress-container">
    <span class="progress-bar"></span>
</div>

<header class="post-header{{#if feature_image}} has-cover{{/if}}">
    <div class="inner">
        <span class="post-info">
            <span class="post-type">{{t "Article"}}</span>
            {{#if tags}}
            <span class="post-count">{{primary_tag.name}}</span>
            {{/if}}
        </span>
        <h1 class="post-title">{{{title}}}</h1>
        <div class="post-meta">
            <div class="post-meta-avatars">
                {{#foreach authors}}
                    {{#if profile_image}}
                        <figure class="post-meta-avatar">
                            <a href="{{url}}" class="author-avatar">
                                <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}" />
                            </a>
                        </figure>
                    {{else}}
                        <figure class="post-meta-avatar avatar"></figure>
                    {{/if}}
                {{/foreach}}
            </div>
            <h4 class="post-meta-author">{{authors separator=", "}}</h4>
            <time datetime="{{date format='DD-MM-YYYY'}}">{{date format="DD MMM YYYY"}}</time> &bull; {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}
        </div>
        {{#if feature_image}}
        <div class="post-cover cover">
            <img
            srcset="{{img_url feature_image size="s"}} 320w,
                    {{img_url feature_image size="m"}} 640w,
                    {{img_url feature_image size="l"}} 960w,
                    {{img_url feature_image size="xl"}} 1920w"
            src="{{img_url feature_image size="xl"}}"
            alt="{{title}}" />
        </div>
        {{/if}}
    </div>
</header>

<main class="content" role="main">
    <article class="{{post_class}}">
        <div class="inner">

            <div class="post-body-wrapper">
                <section class="post-content">
                    {{content}}
                </section>

                <aside class="post-sidebar">
                    <div class="toc-container">
                        <h4 class="toc-title">{{t "Table of Contents"}}</h4>
                        <nav class="toc-nav" id="toc"></nav>
                    </div>
                </aside>
            </div>

            <section class="post-footer">

                {{#if @custom.post_share}}
                <div class="post-share">
                    <span class="post-info-label">{{t "Share"}}</span>
                    {{#match @custom.post_share "Native"}}
                        <button aria-label="{{t "Share"}} {{t "Article"}}" class="post-share-button" id="share-button">{{> "icons/globe"}}</button>
                    {{/match}}
                    {{#match @custom.post_share "Default"}}
                        <a title="Twitter" aria-label="Twitter" class="twitter" href="https://twitter.com/share?text={{title}}&url={{url absolute="true"}}" onclick="window.open(this.href, 'twitter-share', 'width=550,height=235');return false;">{{> "icons/twitter"}}</a>
                        <a title="Facebook" aria-label="Facebook" class="facebook" href="https://www.facebook.com/sharer/sharer.php?u={{url absolute="true"}}" onclick="window.open(this.href, 'facebook-share','width=580,height=296');return false;">{{> "icons/facebook"}}</a>
                        <a title="LinkedIn" aria-label="LinkedIn" class="linkedin" href="https://www.linkedin.com/shareArticle?mini=true&amp;url={{url absolute="true"}}/&amp;title={{title}}" onclick="window.open(this.href, 'linkedin-share', 'width=930,height=720');return false;">{{> "icons/linkedin"}}</a>
                    {{/match}}
                </div>
                {{/if}}

                {{#if tags}}
                <aside class="post-tags">
                    <span class="post-info-label">{{t "Topic"}}</span>
                    {{tags separator=" "}}
                </aside>
                {{/if}}

            </section>

            {{#if comments}}
            <section class="post-comments">
                {{comments color_scheme="dark"}}
            </section>
            {{/if}}

            <section class="post-subscribe">
                <p>{{t "Get the latest posts delivered right to your inbox."}}</p>
                {{subscribe_form placeholder=(t "Your email address") form_class="post-subscribe-form" input_class="post-subscribe-input" button_class="post-subscribe-button"}}
            </section>

            <aside class="post-nav">
                {{#next_post}}
                    <a class="post-nav-next" href="{{url}}">
                        <section class="post-nav-teaser">
                            <i class="icon icon-arrow-left" aria-label="{{t "Next post"}}">{{> "icons/arrow-left"}}</i>
                            <h2 class="post-nav-title">{{title}}</h2>
                            <p class="post-nav-excerpt">{{excerpt words="12"}}&hellip;</p>
                            <p class="post-nav-meta"><time datetime="{{date format='DD-MM-YYYY'}}">{{date format="DD MMM YYYY"}}</time></p>
                        </section>
                    </a>
                {{/next_post}}
                {{#prev_post}}
                    <a class="post-nav-prev" href="{{url}}">
                        <section class="post-nav-teaser">
                            <i class="icon icon-arrow-right" aria-label="{{t "Previous post"}}">{{> "icons/arrow-right"}}</i>
                            <h2 class="post-nav-title">{{title}}</h2>
                            <p class="post-nav-excerpt">{{excerpt words="12"}}&hellip;</p>
                            <p class="post-nav-meta"><time datetime="{{date format='DD-MM-YYYY'}}">{{date format="DD MMM YYYY"}}</time></p>
                        </section>
                    </a>
                {{/prev_post}}
                <div class="clear"></div>
            </aside>

        </div>
    </article>
</main>

{{/post}}

{{#contentFor "scripts"}}
<script>
document.addEventListener("DOMContentLoaded", function () {
    // Native share button
    {{#match @custom.post_share "Native"}}
    var shareBtn = document.getElementById('share-button');
    if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
            try {
                await navigator.share({ url: '{{url absolute="true"}}' });
            } catch (err) {}
        });
    }
    {{/match}}

    // Generate TOC from post headings
    var toc = document.getElementById('toc');
    if (toc) {
        var headings = document.querySelectorAll('.post-content h2, .post-content h3');
        if (headings.length > 1) {
            var html = '<ul>';
            headings.forEach(function(h, i) {
                var id = h.textContent.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
                h.id = id;
                var cls = h.tagName === 'H3' ? ' class="toc-sub"' : '';
                html += '<li' + cls + '><a href="#' + id + '">' + h.textContent + '</a></li>';
            });
            html += '</ul>';
            toc.innerHTML = html;

            // Smooth scroll with Bézier curve
            toc.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    var target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        var start = window.scrollY;
                        var end = target.getBoundingClientRect().top + start - 80;
                        var duration = 600;
                        var startTime = null;
                        function ease(t) {
                            return t < 0.5
                                ? 4 * t * t * t
                                : 1 - Math.pow(-2 * t + 2, 3) / 2;
                        }
                        function scroll(now) {
                            if (!startTime) startTime = now;
                            var elapsed = now - startTime;
                            var progress = Math.min(elapsed / duration, 1);
                            window.scrollTo(0, start + (end - start) * ease(progress));
                            if (progress < 1) requestAnimationFrame(scroll);
                        }
                        requestAnimationFrame(scroll);
                    }
                });
            });
        } else {
            toc.parentElement.style.display = 'none';
            var sidebar = document.querySelector('.post-sidebar');
            if (sidebar) sidebar.style.display = 'none';
            var wrapper = document.querySelector('.post-body-wrapper');
            if (wrapper) wrapper.style.justifyContent = 'center';
        }
    }

    // Sync Ghost comments color scheme with theme
    var observer = new MutationObserver(function () {
        var comments = document.querySelector('ghost-comments');
        if (comments) {
            var isDark = document.documentElement.classList.contains('theme-dark') ||
                (!document.documentElement.classList.contains('theme-light') && window.matchMedia('(prefers-color-scheme: dark)').matches);
            comments.setAttribute('data-color-scheme', isDark ? 'dark' : 'light');
        }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
});
</script>
{{/contentFor}}
